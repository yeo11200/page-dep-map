{
  "name": "@shinjinseop/page-dep-map",
  "version": "0.1.6",
  "description": "Frontend page dependency analyzer — CLI & dashboard for React/Next.js codebases",
  "type": "module",
  "license": "MIT",
  "author": "Jinseop Shin",
  "homepage": "https://github.com/yeo11200/page-dep-map#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeo11200/page-dep-map.git"
  },
  "bugs": {
    "url": "https://github.com/yeo11200/page-dep-map/issues"
  },
  "keywords": [
    "react",
    "nextjs",
    "static-analysis",
    "dependency-graph",
    "page-analysis",
    "complexity",
    "refactoring",
    "code-review",
    "cli",
    "dashboard",
    "ts-morph"
  ],
  "bin": {
    "page-dep-map": "./dist/index.js"
  },
  "files": [
    "dist",
    "dashboard",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prebuild": "rm -rf dashboard && mkdir -p dashboard && cp -R ../dashboard/dist/. dashboard",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "express": "^4.21.0",
    "open": "^10.0.0",
    "ora": "^8.0.0",
    "chalk": "^5.0.0",
    "ts-morph": "^24.0.0",
    "fast-glob": "^3.3.0"
  },
  "devDependencies": {
    "@page-dep-map/analyzer": "workspace:*",
    "@page-dep-map/shared": "workspace:*",
    "@types/express": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
