{
  "name": "@shinjinseop/page-dep-map-vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin that injects the page-dep-map inspect helper into the host app during dev",
  "license": "MIT",
  "author": "Jinseop Shin",
  "homepage": "https://github.com/yeo11200/page-dep-map#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeo11200/page-dep-map.git"
  },
  "bugs": {
    "url": "https://github.com/yeo11200/page-dep-map/issues"
  },
  "keywords": [
    "vite-plugin",
    "react",
    "inspect",
    "page-dep-map",
    "devtools"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "vite": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@page-dep-map/inspect-helper": "workspace:*",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vite": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
